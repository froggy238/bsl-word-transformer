      ],
      "source": [
        "import numpy as np\n",
        "import pandas as pd\n",
        "\n",
        "GROUPS = {\n",
        "    'A: Transformer + aug': 'transformer_aug',\n",
        "    'B: Transformer no-aug': 'transformer_noaug',\n",
        "    'C: LSTM + aug': 'lstm_aug',\n",
        "    'D: LSTM no-aug': 'lstm_noaug',\n",
        "}\n",
        "\n",
        "best_per_group = {}\n",
        "rows = []\n",
        "for name, prefix in GROUPS.items():\n",
        "    ckpts = sorted(Path('results/runs').glob(prefix + '_s4[234]/best.pt'))\n",
        "    accs = {p: torch.load(p, map_location='cpu')['val_acc'] for p in ckpts}\n",
        "    best_per_group[prefix] = max(accs, key=accs.get)\n",
        "    rows.append({'run group': name,\n",
        "                 'val acc mean': np.mean(list(accs.values())),\n",
        "                 'val acc std': np.std(list(accs.values())),\n",
        "                 'n seeds': len(accs),\n",
        "                 'best seed ckpt': str(best_per_group[prefix])})\n",
        "\n",
        "summary = pd.DataFrame(rows)\n",
        "summary.to_csv('results/grid_summary.csv', index=False)\n",
        "summary.round(4)"
      ],
      "id": "3mcyD0MnJG6X"
    },
