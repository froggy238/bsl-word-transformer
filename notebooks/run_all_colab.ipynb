          ]
        }
      ],
      "source": [
        "import matplotlib.pyplot as plt\n",
        "\n",
        "fig, axes = plt.subplots(1, 2, figsize=(13, 4.5), sharey=True)\n",
        "for ax, arch in zip(axes, ('transformer', 'lstm')):\n",
        "    for aug, style in (('aug', '-'), ('noaug', '--')):\n",
        "        for seed in (42, 43, 44):\n",
        "            m = pd.read_csv(f'results/runs/{arch}_{aug}_s{seed}/metrics.csv')\n",
        "            ax.plot(m['epoch'], m['val_acc'], style, alpha=0.6,\n",
        "                    label=f'{aug} s{seed}' if seed == 42 else None)\n",
        "    ax.set_title(arch)\n",
        "    ax.set_xlabel('epoch')\n",
        "    ax.legend()\n",
        "axes[0].set_ylabel('val accuracy')\n",
        "plt.tight_layout()\n",
        "plt.savefig('results/learning_curves.png', dpi=120)\n",
        "plt.show()\n",
        "\n",
        "t_aug = summary.loc[summary['run group'].str.startswith('A'), 'val acc mean'].iat[0]\n",
        "t_no = summary.loc[summary['run group'].str.startswith('B'), 'val acc mean'].iat[0]\n",
        "l_aug = summary.loc[summary['run group'].str.startswith('C'), 'val acc mean'].iat[0]\n",
        "l_no = summary.loc[summary['run group'].str.startswith('D'), 'val acc mean'].iat[0]\n",
        "print(f'RQ2 ablation (val, mean over seeds):')\n",
        "print(f'  transformer: aug {t_aug:.3f} vs no-aug {t_no:.3f} -> delta {t_aug - t_no:+.3f}')\n",
        "print(f'  lstm:        aug {l_aug:.3f} vs no-aug {l_no:.3f} -> delta {l_aug - l_no:+.3f}')"
